      "secondary": {
        "height": 56,
        "borderRadius": 28,
        "backgroundColor": "#1A265C",
        "justifyContent": "center",
        "alignItems": "center",
        "paddingHorizontal": 24,
        "borderWidth": 1,
        "borderColor": "#00D4AA"
      },
      "sos": {
        "width": 120,
        "height": 120,
        "borderRadius": 60,
        "backgroundColor": "#FF3B30",
        "justifyContent": "center",
        "alignItems": "center",
        "elevation": 20,
        "shadowColor": "#FF3B30",
        "shadowOpacity": 0.8,
        "shadowRadius": 20
      }
    },
    "cards": {
      "modeCard": {
        "backgroundColor": "#111945",
        "borderRadius": 16,
        "padding": 16,
        "marginBottom": 16,
        "borderWidth": 1,
        "borderColor": "rgba(255,255,255,0.05)"
      },
      "activeCard": {
        "backgroundColor": "#1A265C",
        "borderColor": "#00D4AA",
        "borderWidth": 2
      }
    },
    "inputs": {
      "default": {
        "height": 56,
        "backgroundColor": "#111945",
        "borderRadius": 12,
        "paddingHorizontal": 16,
        "color": "#F5F5F0",
        "borderWidth": 1,
        "borderColor": "rgba(255,255,255,0.1)",
        "fontSize": 16
      }
    }
  },
