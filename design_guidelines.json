      "family": "Ionicons",
      "mapping": {
        "home": "home",
        "shield": "shield-checkmark",
        "alert": "alert-circle",
        "location": "location",
        "navigate": "navigate",
        "call": "call",
        "settings": "settings-sharp",
        "walk": "walk",
        "car": "car-sport",
        "bus": "bus",
        "close": "close",
        "menu": "menu"
      }
    }
  },
  "implementation_rules": {
    "styling": "StyleSheet.create",
    "theme": "Dark Mode Only",
    "navigation": "React Navigation (Stack + Bottom Tabs)",
    "safeArea": "Must wrap all screens in SafeAreaView from react-native-safe-area-context",
    "keyboard": "Must use KeyboardAvoidingView for forms",
    "touchables": "Use TouchableOpacity with activeOpacity={0.8} or Pressable",
    "layout": "Flexbox",
    "data_testid": "All interactive elements must have a unique testID prop"
  },
  "instructions_to_main_agent": [
    "1. Initialize the project with Expo and React Navigation.",
    "2. Create a 'theme.js' file exporting the colors and typography defined here.",
    "3. Build the 'SOSButton' component first - it is the core feature. Make it pulse.",
    "4. Implement the Bottom Tab Bar with a persistent 'SOS' button in the center (floating if possible).",
    "5. Use the provided image URLs for the Travel Mode cards on the Home Screen.",
    "6. Ensure all touch targets are at least 44x44 points.",
    "7. Do NOT use any CSS-in-JS libraries like Styled Components. Use native StyleSheet.",
    "8. For the Map, if 'react-native-maps' is too complex for MVP, use a static image background with overlay markers for the prototype.",
    "9. Validate all inputs (email, phone) before submission.",
    "10. Add 'testID' to every button and input for testing."
  ]
}