{
  "identity": {
    "name": "SafeHer",
    "archetype": "The Performance Pro",
    "tone": "Trusted, Alert, Empowering, Precision",
    "description": "A high-performance safety tool for women. Dark mode first, high contrast, tactical but modern."
  },
  "design_system": {
    "colors": {
      "background": "#0A0F2C",
      "surface": "#111945",
      "surfaceHighlight": "#1A265C",
      "primary": "#00D4AA",
      "primaryActive": "#00A888",
      "danger": "#FF3B30",
      "dangerActive": "#D63026",
      "textPrimary": "#F5F5F0",
      "textSecondary": "#94A3B8",
      "success": "#32D74B",
      "warning": "#FFD60A",
      "overlay": "rgba(10, 15, 44, 0.85)"
    },
    "typography": {
      "fontFamily": "System",
      "weights": {
        "regular": "400",
        "medium": "500",
        "bold": "700",
        "heavy": "900"
      },
      "sizes": {
        "h1": { "fontSize": 32, "lineHeight": 40, "fontWeight": "700", "letterSpacing": 0.5 },
        "h2": { "fontSize": 24, "lineHeight": 32, "fontWeight": "700", "letterSpacing": 0.3 },
        "h3": { "fontSize": 20, "lineHeight": 28, "fontWeight": "600", "letterSpacing": 0.2 },
        "body": { "fontSize": 16, "lineHeight": 24, "fontWeight": "400" },
        "small": { "fontSize": 14, "lineHeight": 20, "fontWeight": "400" },
        "caption": { "fontSize": 12, "lineHeight": 16, "fontWeight": "400", "color": "#94A3B8" }
      }
    },
    "spacing": {
      "xs": 4,
      "s": 8,
      "m": 16,
      "l": 24,
      "xl": 32,
      "xxl": 48
    },
    "borderRadius": {
      "s": 8,
      "m": 12,
      "l": 16,
      "xl": 24,
      "full": 9999
    },
    "shadows": {
      "card": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 4 },
        "shadowOpacity": 0.3,
        "shadowRadius": 8,
        "elevation": 5
      },
      "glow": {
        "shadowColor": "#00D4AA",
        "shadowOffset": { "width": 0, "height": 0 },
        "shadowOpacity": 0.6,
        "shadowRadius": 16,
        "elevation": 10
      }
    }
  },
  "components": {
    "buttons": {
      "primary": {
        "height": 56,
        "borderRadius": 28,
        "backgroundColor": "#00D4AA",
        "justifyContent": "center",
        "alignItems": "center",
        "paddingHorizontal": 24
